# === 必須 ===
# 現金自動記帳マスターのスプレッドシートID
MASTER_SPREADSHEET_ID=your_master_spreadsheet_id

# Gemini API キー
GEMINI_API_KEY=your_gemini_api_key

# === Google 認証（ローカル開発時のみ） ===
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# === オプション ===
# 注意: 現金出納帳の自動作成はサポートしていません。
# G列のシートリンクは手動で入力してください。
# 以下のテンプレート系設定は現在は使われませんが、将来の拡張用に残しています。
# INDIVIDUAL_TEMPLATE_SPREADSHEET_ID=
# CORPORATE_TEMPLATE_SPREADSHEET_ID=
# CASHBOOK_OUTPUT_FOLDER_ID=

# マスターシート名（デフォルト: シート1）
# MASTER_SHEET_NAME=シート1

# マスターのデータ開始行（デフォルト: 2）
# MASTER_DATA_START_ROW=2

# 処理対象の記帳区分（デフォルト: 当方記帳）
# MASTER_TARGET_ENTRY_TYPE=当方記帳

# 記帳対象タブ名（固定、既定: 入力用）
# ファイル名（例: 【顧客名】現金出納帳）とは別。各出納帳スプレッドシート内に
# この名前のタブが存在している前提。
# CASHBOOK_SHEET_NAME=入力用

# 使用済み行判定列（0-indexed、カンマ区切り）
# CASHBOOK_OCCUPIED_CHECK_COLUMNS=0,1,2

# データ開始行
# CASHBOOK_DATA_START_ROW=5

# 列マッピング（JSON、実シート構成に合わせた既定値）
# A=0, B=1, C=2 (勘定科目コード), F=5, G=6, K=10, M=12
# CASHBOOK_COLUMN_MAP={"ファイルリンク":0,"日付":1,"勘定科目コード":2,"取引先":5,"税区分":6,"摘要":10,"支出金額":12}

# 勘定科目名 → 勘定科目コード の変換表（JSON）
# 空だと C列には書き込まない（既存値/数式を保護）
# CASHBOOK_ACCOUNT_CODE_MAP={"消耗品費":"401","旅費交通費":"412"}

# 処理対象外にするファイル名プレフィックス（カンマ区切り）
# EXCLUDED_FILE_NAME_PREFIXES=[済],【済】

# 保護列
# CASHBOOK_PROTECTED_COLUMNS=3,13

# 数式コピー対象列
# CASHBOOK_FORMULA_COPY_COLUMNS=3,13

# 要手入力行のエラー詳細を書き込む列 (0-indexed、既定: 14=O列)
# 通常の正常記帳行では触らない。C列には短文固定「※要手入力」のみ入れる。
# CASHBOOK_ERROR_DETAIL_COLUMN=14

# AI_MODEL=gemini-2.5-flash
# AI_CONFIDENCE_THRESHOLD=0.7
# RESERVATION_TTL_MINUTES=30
# DRY_RUN=false
# LOG_LEVEL=INFO

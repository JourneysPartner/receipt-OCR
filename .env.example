# === 必須 ===
DRIVE_FOLDER_ID=your_drive_folder_id_here
SPREADSHEET_ID=your_spreadsheet_id_here
GEMINI_API_KEY=your_gemini_api_key_here

# === Google 認証（ローカル開発時のみ） ===
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json

# === オプション ===
# CASHBOOK_SHEET_NAME=現金出納帳
# PROCESS_LOG_SHEET_NAME=処理管理
# AI_LOG_SHEET_NAME=AI詳細ログ

# 使用済み行判定列（カンマ区切り、0-indexed、いずれかに値があれば使用済み）
# CASHBOOK_OCCUPIED_CHECK_COLUMNS=0,1,2

# データ開始行 (1-indexed)
# CASHBOOK_DATA_START_ROW=5

# 列マッピング（JSON）
# CASHBOOK_COLUMN_MAP={"ファイルリンク":0,"日付":1,"摘要":2,"取引先":4,"勘定科目":5,"税区分":6,"収入金額":7,"支出金額":8}

# 保護列（0-indexed）
# CASHBOOK_PROTECTED_COLUMNS=3,13

# 数式コピー対象列（0-indexed）
# CASHBOOK_FORMULA_COPY_COLUMNS=3,13

# OCR_ENGINE=vision
# AI_ENGINE=gemini
# AI_MODEL=gemini-2.5-flash
# AI_CONFIDENCE_THRESHOLD=0.7

# 行予約の有効期限（分）
# RESERVATION_TTL_MINUTES=30

# DRY_RUN=false
# LOG_LEVEL=INFO
